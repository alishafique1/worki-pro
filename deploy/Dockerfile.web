FROM node:22.12.0-alpine3.20 AS build

# REACT_APP_API_URL is baked into the Vite bundle at build time.
# Set this to your production API domain, e.g. https://api.thehelper.ca
ARG REACT_APP_API_URL=https://api.thehelper.ca
ENV REACT_APP_API_URL=$REACT_APP_API_URL

WORKDIR /app

# Workspace setup — root package.json links .wasp/out/* as workspaces
COPY package.json package-lock.json ./

# Wasp SDK and libs (needed by the wasp() Vite plugin and client code)
COPY .wasp/out/sdk .wasp/out/sdk
COPY .wasp/out/libs .wasp/out/libs

# Server package.json only — workspace resolution needs it, actual server code not required
COPY .wasp/out/server/package.json .wasp/out/server/package.json

# User source and config
COPY src ./src
COPY public ./public
COPY vite.config.ts tsconfig.json ./

RUN npm install
RUN npx vite build --outDir /dist

# ── Production image ─────────────────────────────────────────────────────────
FROM nginx:1.27-alpine
COPY --from=build /dist /usr/share/nginx/html
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
